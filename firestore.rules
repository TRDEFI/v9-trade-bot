rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- PRIMITIVES ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return request.auth.token.email_verified == true; }
    function isValidId(id) { return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Auth Tokens check
    function isOwner(ownerId) { return isSignedIn() && request.auth.uid == ownerId; }

    // --- VALIDATION HELPERS ---
    function isBotStatus(data) {
      return data.keys().hasAll(['isRunning', 'capital', 'ownerId']) &&
             data.isRunning is bool &&
             data.capital is number &&
             data.ownerId is string && data.ownerId.size() > 0 && data.ownerId.size() <= 128 && data.ownerId == request.auth.uid;
    }
    
    function isBotConfig(data) {
      return data.keys().hasAll(['ownerId']) &&
             data.ownerId is string && data.ownerId.size() > 0 && data.ownerId.size() <= 128 && data.ownerId == request.auth.uid;
    }

    // --- MATCH BLOCKS ---
    match /system/{documentId} {
      allow read: if isSignedIn() && existing().ownerId == request.auth.uid;
      
      allow create: if isSignedIn() && isVerified() && isValidId(documentId) && (
        (documentId == 'status' && isBotStatus(incoming()) && incoming().keys().size() == 3) ||
        (documentId == 'config' && isBotConfig(incoming()) && incoming().keys().hasOnly(['baseUrl', 'apiKey', 'ownerId']))
      );
      
      allow update: if isSignedIn() && isVerified() && isValidId(documentId) && existing().ownerId == request.auth.uid && incoming().ownerId == existing().ownerId && (
        (documentId == 'status' && isBotStatus(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['isRunning', 'capital', 'sessionStart'])) ||
        (documentId == 'config' && isBotConfig(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['baseUrl', 'apiKey']))
      );
      
      allow delete: if false; 
    }
    
    match /users/{userId} {
      allow read: if isSignedIn() && userId == request.auth.uid;
      allow create, update, delete: if false; // Users managed through admin SDK or another trusted environment
    }

  }
}
